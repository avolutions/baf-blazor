@using Avolutions.Baf.Core.Resources
@using Microsoft.Extensions.Localization
@using MudBlazor

@inject IStringLocalizer<SharedResources> L

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1">
            @ContentText 
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Default" OnClick="@Cancel">@L["Button.Cancel"]</MudButton>
        <MudButton Color="@ActionButtonColor" Variant="Variant.Filled" OnClick="@Submit">@ActionButtonText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public required string ContentText  { get; set; }
    [Parameter] public required string ActionButtonText { get; set; }
    [Parameter] public required Color ActionButtonColor { get; set; }
    
    private void Submit() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}